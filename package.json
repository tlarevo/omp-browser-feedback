{
	"name": "omp-browser-feedback",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.14",
	"workspaces": {
		"packages": ["packages/*"],
		"catalog": {
			"@types/bun": "^1.3.14",
			"arktype": "^2.2.0",
			"linkedom": "^0.18.12"
		}
	},
	"scripts": {
		"check:types": "bun run --workspaces --if-present check:types",
		"test": "bun run --workspaces --if-present test",
		"build:extension": "bun --cwd=packages/browser-extension run build"
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	}
}
