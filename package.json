{
	"name": "omp-browser-feedback",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.14",
	"workspaces": {
		"packages": [
			"packages/*"
		],
		"catalog": {
			"@types/bun": "^1.3.14",
			"@types/chrome": "^0.1.29",
			"arktype": "^2.2.0",
			"linkedom": "^0.18.12"
		}
	},
	"scripts": {
		"check": "biome check .github package.json tsconfig*.json scripts test packages/*/package.json packages/*/tsconfig.json packages/*/src packages/*/test packages/browser-extension/manifest.json && bun run check:types && bun run check:chrome-contract",
		"check:types": "tsgo -p tsconfig.json --noEmit && bun run --workspaces --if-present check:types",
		"check:omp-head": "bun scripts/check-against-omp-head.ts",
		"test": "bun test ./test/*.test.ts && bun run --workspaces --if-present test",
		"build:omp-extension": "bun --cwd=packages/browser-omp-extension run build",
		"build:extension": "bun --cwd=packages/browser-extension run build",
		"check:chrome-contract": "bun scripts/check-chrome-contract-drift.ts",
		"generate:chrome-contract": "bun scripts/export-chrome-contract.ts contracts/chrome-contract.json"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "catalog:",
		"@types/chrome": "catalog:",
		"@typescript/native-preview": "7.0.0-dev.20260527.1",
		"typescript": "^6.0.3",
		"typescript-language-server": "^5.3.0"
	},
	"engines": {
		"bun": ">=1.3.14"
	}
}
