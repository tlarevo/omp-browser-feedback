{
	"type": "module",
	"name": "omp-browser-feedback",
	"version": "0.0.5",
	"description": "OMP extension for browser DOM feedback via the Chrome extension and local broker",
	"homepage": "https://omp.sh",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tlarevo/omp-browser-feedback.git"
	},
	"bugs": {
		"url": "https://github.com/tlarevo/omp-browser-feedback/issues"
	},
	"license": "MIT",
	"omp": {
		"extensions": [
			"./dist/extension.js"
		]
	},
	"main": "./dist/extension.js",
	"types": "./dist/types/extension.d.ts",
	"scripts": {
		"build": "bun build src/extension.ts --outfile dist/extension.js --target=bun --format=esm && tsc -p tsconfig.publish.json",
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write .",
		"test": "bun test --parallel"
	},
	"devDependencies": {
		"@oh-my-pi/browser-broker": "workspace:*",
		"@oh-my-pi/browser-protocol": "workspace:*",
		"@oh-my-pi/pi-coding-agent": "*",
		"@types/bun": "catalog:"
	},
	"peerDependencies": {
		"@oh-my-pi/pi-coding-agent": "*"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"exports": {
		".": {
			"types": "./dist/types/extension.d.ts",
			"import": "./dist/extension.js"
		}
	}
}
