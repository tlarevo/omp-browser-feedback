{
	"type": "module",
	"name": "@oh-my-pi/browser-extension",
	"version": "16.1.23",
	"description": "Chrome extension for sending browser feedback to OMP",
	"homepage": "https://omp.sh",
	"license": "MIT",
	"scripts": {
		"build": "bun build src/background-entry.ts src/content-entry.ts src/popup/app.ts --outdir dist --target browser",
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write .",
		"test": "bun test --parallel"
	},
	"dependencies": {
		"@oh-my-pi/browser-protocol": "workspace:*",
		"linkedom": "catalog:"
	},
	"devDependencies": {
		"@oh-my-pi/browser-broker": "workspace:*",
		"@types/bun": "catalog:",
		"playwright": "^1.50.0"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src",
		"manifest.json",
		"README.md",
		"CHANGELOG.md"
	]
}
