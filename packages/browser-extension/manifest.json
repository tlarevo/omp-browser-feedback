{
	"manifest_version": 3,
	"name": "OMP Browser Feedback",
	"version": "0.1.0",
	"description": "Select DOM elements and send feedback to an active OMP session.",
	"permissions": ["activeTab", "scripting", "storage", "tabs"],
	"host_permissions": ["http://127.0.0.1:*/*"],
	"icons": {
		"16": "icons/icon16.png",
		"32": "icons/icon32.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"background": {
		"service_worker": "dist/background-entry.js"
	},
	"action": {
		"default_popup": "src/popup/index.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"32": "icons/icon32.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		},
		"default_title": "OMP Browser Feedback"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["dist/content-entry.js"],
			"run_at": "document_idle"
		}
	]
}
