{
	"manifest_version": 3,
	"name": "OMP Browser Feedback",
	"version": "0.1.0",
	"description": "Select DOM elements and send feedback to an active OMP session.",
	"permissions": ["activeTab", "scripting", "storage", "tabs"],
	"host_permissions": ["http://127.0.0.1:*/*"],
	"background": {
		"service_worker": "dist/background-entry.js"
	},
	"action": {
		"default_popup": "src/popup/index.html"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["dist/content-entry.js"],
			"run_at": "document_idle"
		}
	]
}
