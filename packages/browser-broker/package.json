{
	"type": "module",
	"name": "@oh-my-pi/browser-broker",
	"version": "0.0.1",
	"description": "Local loopback broker for OMP browser feedback",
	"homepage": "https://omp.sh",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tlarevo/omp-browser-feedback.git"
	},
	"bugs": {
		"url": "https://github.com/tlarevo/omp-browser-feedback/issues"
	},
	"license": "MIT",
	"private": true,
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"bin": {
		"omp-browser-broker": "src/cli.ts"
	},
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write .",
		"test": "bun test --parallel"
	},
	"dependencies": {
		"@oh-my-pi/browser-protocol": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src",
		"README.md",
		"CHANGELOG.md"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	}
}
